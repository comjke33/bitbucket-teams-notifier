#!/bin/sh

remote="$1"
url="$2"

# Git에서 생성한 빈 해시값 (삭제된 브랜치 확인용)
zero=$(git hash-object --stdin </dev/null | tr '[0-9a-f]' '0')

# 푸시되는 브랜치 정보를 표준 입력(stdin)으로 읽어옵니다.
while read local_ref local_oid remote_ref remote_oid
do
	# 1. 브랜치를 삭제하는 push인 경우(local_oid가 0000...)에는 팀즈를 띄우지 않고 건너뜁니다.
	if [ "$local_oid" = "$zero" ]; then
		continue
	fi

	# 2. 현재 푸시하는 로컬 브랜치명 추출 (refs/heads/feature-abc -> feature-abc)
	USER_NAME=$(git config user.name)
	BRANCH=$(git rev-parse --abbrev-ref HEAD)
	
	# 3. 최신 커밋 메시지 추출
	COMMIT_MSG=$(git log -1 --pretty=%B)

	# 4. 파이썬 스크립트 실행
	python send_pr.py "$USER_NAME" "$BRANCH" "$COMMIT_MSG" >> send_pr.log 2>&1
	
	# 하나의 브랜치 push에 대해 한 번만 실행하고 루프를 종료합니다.
	break
done

exit 0